{
  "header": "# 更新日志",
  "types": [
    { "type": "feat", "section": "✨ 新功能" },
    { "type": "fix", "section": "🐛 修复" },
    { "type": "perf", "section": "⚡ 性能优化" },
    { "type": "refactor", "section": "♻️ 重构" },
    { "type": "docs", "section": "📝 文档" },
    { "type": "test", "section": "✅ 测试" },
    { "type": "build", "section": "📦 构建" },
    { "type": "ci", "section": "👷 CI" },
    { "type": "chore", "hidden": true }
  ],
  "commitUrlFormat": "https://github.com/LeeGuangYao/e/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/LeeGuangYao/e/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://github.com/LeeGuangYao/e/issues/{{id}}",
  "releaseCommitMessageFormat": "chore(release): {{currentTag}}"
}
